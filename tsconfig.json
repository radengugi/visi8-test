{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    /**
     * Types untuk Jest
     *
     * Penjelasan untuk interview:
     * - "jest" type enable TypeScript mengenali Jest globals:
     *   - describe, it, test, expect, jest, beforeEach, afterEach, dll
     * - Fix error: "Cannot find name 'describe'"
     * - Perlu install @types/jest package
     */
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
